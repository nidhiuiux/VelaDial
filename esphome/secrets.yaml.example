# ============================================================================
# VelaDial — ESPHome secrets template
# ============================================================================
#
# This is a TEMPLATE file with placeholder values. Copy it to `secrets.yaml`
# in the same directory (or in your Home Assistant `/config/esphome/`
# directory) and fill in real values. NEVER commit the real `secrets.yaml`.
#
# Both `secrets.yaml` and `esphome/secrets.yaml` are excluded by `.gitignore`.
# This `.example` file is intentionally tracked.
#
# Generate a new ESPHome API encryption key with:
#   esphome wizard <node-name>.yaml
# or use any 32-byte base64 string. The same `encryption_key` should be set
# in Home Assistant when adopting the device.
#
# See `docs/setup/raspberry_pi_home_assistant_setup.md` §10 for full setup
# guidance.
# ============================================================================

# --- Wi-Fi (2.4 GHz IoT SSID recommended) ---
wifi_ssid: "your-wifi-ssid"
wifi_password: "your-wifi-password"

# --- Fallback access point (used only if Wi-Fi association fails) ---
fallback_ap_password: "set-a-long-fallback-ap-password"

# --- ESPHome native API (Home Assistant integration encryption key) ---
# 32 bytes, base64-encoded. Example length: 44 chars including padding.
# Generate with `openssl rand -base64 32` or `esphome wizard`.
encryption_key: "REPLACE_WITH_A_REAL_BASE64_32_BYTE_KEY"

# --- OTA update password ---
# The door-side YAML uses `ota_key`; the bedside YAML uses `ota_password`.
# They can be the same value or different — both are kept here as separate
# placeholders so each device YAML resolves cleanly.
ota_key: "set-a-long-ota-password"
ota_password: "set-a-long-ota-password"

# ============================================================================
# Do NOT put Tuya local keys, Home Assistant long-lived access tokens, or
# any other credentials in this file. Those belong in Home Assistant's own
# configuration (e.g. LocalTuya integration), not in ESPHome secrets.
# ============================================================================
